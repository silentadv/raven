generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String @id @default(cuid())
  discord_id String @unique

  level  Int @default(1)
  xp     Int @default(0)
  xp_cap Int @default(1000)
  points Int @default(10)

  hp         Int @default(100)
  strength   Int @default(1)
  agility    Int @default(1)
  magic      Int @default(1)
  resistance Int @default(1)

  created_at DateTime @default(now())

  items     Item[]
  cooldowns Cooldown[]

  @@map("users")
}

model Item {
  id      String @id @default(cuid())
  item_id String
  user_id String
  count   Int    @default(0)

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, item_id])
  @@map("items")
}

enum CooldownType {
  DAILY
}

model Cooldown {
  id      String       @id @default(cuid())
  user_id String
  type    CooldownType
  date    DateTime

  user User @relation(fields: [user_id], references: [id])

  @@unique([type, user_id])
  @@map("cooldowns")
}
